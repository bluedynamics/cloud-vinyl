{
  "$schema": "http://json-schema.org/draft-07/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["image"],
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "description": "Number of operator replicas. >1 requires leaderElection.enabled: true."
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operator", "agent"],
      "properties": {
        "operator": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "repository": {"type": "string"},
            "tag": {"type": "string"},
            "pullPolicy": {"type": "string", "enum": ["Always", "IfNotPresent", "Never"]}
          }
        },
        "agent": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "repository": {"type": "string"},
            "tag": {"type": "string"},
            "pullPolicy": {"type": "string", "enum": ["Always", "IfNotPresent", "Never"]}
          }
        }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {"type": "object"}
    },
    "nameOverride": {"type": "string"},
    "fullnameOverride": {"type": "string"},
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": {"type": "boolean"},
        "annotations": {"type": "object"},
        "name": {"type": "string"}
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requests": {
          "type": "object",
          "properties": {
            "cpu": {"type": "string"},
            "memory": {"type": "string"}
          }
        },
        "limits": {
          "type": "object",
          "properties": {
            "cpu": {"type": "string"},
            "memory": {"type": "string"}
          }
        }
      }
    },
    "leaderElection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {"type": "boolean"}
      }
    },
    "operatorFlags": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "metricsAddr": {"type": "string"},
        "probeAddr": {"type": "string"},
        "agentClientTimeout": {"type": "string"}
      }
    },
    "webhook": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "certManager": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {"type": "boolean"}
          }
        },
        "tls": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "caCert": {"type": "string"},
            "cert": {"type": "string"},
            "key": {"type": "string"}
          }
        }
      }
    },
    "monitoring": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "prometheusRules": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {"type": "boolean"}
          }
        },
        "serviceMonitor": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {"type": "boolean"},
            "interval": {
              "type": "string",
              "pattern": "^[0-9]+(s|m|h)$"
            },
            "scrapeTimeout": {
              "type": "string",
              "pattern": "^[0-9]+(s|m|h)$"
            },
            "additionalLabels": {"type": "object"}
          }
        }
      }
    },
    "installCRDs": {"type": "boolean"},
    "nodeSelector": {"type": "object"},
    "tolerations": {
      "type": "array",
      "items": {"type": "object"}
    },
    "affinity": {"type": "object"},
    "podSecurityContext": {"type": "object"},
    "securityContext": {"type": "object"}
  }
}
