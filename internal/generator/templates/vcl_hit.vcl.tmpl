
sub vcl_hit {
{{- if .HasSoftPurge }}
    if (obj.ttl >= 0s) {
        return(deliver);
    }
    # Soft-purge: serve stale while revalidating if within grace period
    if (obj.ttl + obj.grace > 0s) {
        return(deliver);
    }
    # Object is within keep period for a soft-purged object
    if (obj.ttl + obj.keep > 0s) {
        return(restart);
    }
{{- else }}
    if (obj.ttl >= 0s) {
        return(deliver);
    }
{{- end }}
{{ if .Spec.VCL.Snippets.VCLHit }}
    # --- custom vcl_hit snippet ---
    {{ .Spec.VCL.Snippets.VCLHit }}
    # --- end custom vcl_hit snippet ---
{{ end }}
    return(miss);
}
